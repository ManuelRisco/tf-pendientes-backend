# Backend Environment Variables
# Estas variables serán reemplazadas automáticamente por Railway en producción.
# Para desarrollo local (XAMPP), copia este archivo a .env y ajusta los valores.

MYSQLHOST=localhost
MYSQLDATABASE=tf_pendientes
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLPORT=3306

# URL del Frontend (Para permitir CORS)
FRONTEND_URL=http://localhost:5173
